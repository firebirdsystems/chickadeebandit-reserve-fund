{
  "id": "reserve-fund",
  "contexts": ["household", "shared_space"],
  "name": "Reserve Fund Dashboard",
  "version": "2.0.0",
  "description": "Track organization capital reserve funds — balances, goals, deposit/withdrawal ledger, capital project planning, and balance-over-time charts. Board manages; all members can view.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "organization",
  "tags": ["hoa", "reserve", "finance", "capital", "board"],
  "exports": ["funds-list"],
  "data_access": {
    "reads": ["family.groups"],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": true
  },
  "storage": "db",
  "db_plaintext_columns": ["operation"],
  "icon": "🏦",
  "nav": { "label": "Reserve Funds" },
  "row_policies": {
    "settings": { "kind": "app_config" },
    "funds": {
      "kind": "owner_or_visibility",
      "member_column": "created_by",
      "visibility_column": "visibility",
      "everyone_values": ["everyone"],
      "write_privileged_only": true,
      "privileged_groups": [{ "settings_table": "settings", "settings_key": "board_group_id" }]
    },
    "manual_tx": {
      "kind": "owner_or_visibility",
      "member_column": "created_by",
      "visibility_column": "visibility",
      "everyone_values": ["everyone"],
      "write_privileged_only": true,
      "privileged_groups": [{ "settings_table": "settings", "settings_key": "board_group_id" }]
    },
    "projects": {
      "kind": "owner_or_visibility",
      "member_column": "created_by",
      "visibility_column": "visibility",
      "everyone_values": ["everyone"],
      "write_privileged_only": true,
      "privileged_groups": [{ "settings_table": "settings", "settings_key": "board_group_id" }]
    },
    "imported_tx": { "kind": "endpoint_only", "read": "everyone" }
  },
  "admin_config": {
    "settings_table": "settings",
    "keys": ["board_group_id"]
  },
  "store_acls": {
    "funds-list": {
      "write": {
        "require_group_setting": { "settings_table": "settings", "settings_key": "board_group_id" }
      }
    }
  },
  "financial_ledger_imports": {
    "transactions": {
      "table": "imported_tx",
      "funds_table": "funds",
      "allowed_source_apps": ["dues-contributions"],
      "require_group_setting": { "settings_table": "settings", "settings_key": "board_group_id" }
    }
  }
}
